{
  "name": "@shawnos/video",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "PORT=3005 remotion studio src/index.ts",
    "render": "remotion render src/index.ts LeadMagnetV3 out/lead-magnet-v3-linkedin.mp4",
    "render:linkedin": "remotion render src/index.ts LeadMagnetV3 out/lead-magnet-v3-linkedin.mp4",
    "render:reels": "remotion render src/index.ts LeadMagnetV3Reels out/lead-magnet-v3-reels.mp4",
    "render:landscape": "remotion render src/index.ts LeadMagnetV3Landscape out/lead-magnet-v3-landscape.mp4",
    "render:all": "npm run render:linkedin && npm run render:reels && npm run render:landscape",
    "render:v1": "remotion render src/index.ts LeadMagnet out/lead-magnet-linkedin.mp4",
    "render:nio-landscape": "remotion render src/index.ts NioLandscape out/nio-landscape.mp4",
    "render:nio-linkedin": "remotion render src/index.ts NioLinkedIn out/nio-linkedin.mp4",
    "render:nio-reels": "remotion render src/index.ts NioReels out/nio-reels.mp4",
    "render:nio-all": "npm run render:nio-landscape && npm run render:nio-linkedin && npm run render:nio-reels",
    "render:tiktok": "remotion render src/index.ts TikTok-nio-intro out/tiktok-nio-intro.mp4",
    "render:tiktok-all": "npm run render:tiktok && remotion render src/index.ts TikTok-ai-setup out/tiktok-ai-setup.mp4 && remotion render src/index.ts TikTok-api-costs out/tiktok-api-costs.mp4 && remotion render src/index.ts TikTok-mcp-servers out/tiktok-mcp-servers.mp4 && remotion render src/index.ts TikTok-sqlite-repo out/tiktok-sqlite-repo.mp4 && remotion render src/index.ts TikTok-remotion-videos out/tiktok-remotion-videos.mp4",
    "render:reel-1": "remotion render src/index.ts NioReel-ApiCosts out/nio-reel-api-costs.mp4",
    "render:reel-2": "remotion render src/index.ts NioReel-ClaudeCodeWrong out/nio-reel-claude-code-wrong.mp4",
    "render:reel-3": "remotion render src/index.ts NioReel-ApiWrappers out/nio-reel-api-wrappers.mp4",
    "render:reel-4": "remotion render src/index.ts NioReel-McpServers out/nio-reel-mcp-servers.mp4",
    "render:reel-5": "remotion render src/index.ts NioReel-RemotionMeta out/nio-reel-remotion-meta.mp4",
    "render:reel-all": "npm run render:reel-1 && npm run render:reel-2 && npm run render:reel-3 && npm run render:reel-4 && npm run render:reel-5",
    "render:antislop-tiktok": "remotion render src/index.ts AntiSlopReels out/antislop-tiktok.mp4",
    "render:antislop-linkedin": "remotion render src/index.ts AntiSlopLinkedIn out/antislop-linkedin.mp4",
    "render:antislop-landscape": "remotion render src/index.ts AntiSlopLandscape out/antislop-landscape.mp4",
    "render:antislop-all": "npm run render:antislop-tiktok && npm run render:antislop-linkedin && npm run render:antislop-landscape",
    "render:antislop60-tiktok": "remotion render src/index.ts AntiSlop60Reels out/antislop60-tiktok.mp4",
    "render:antislop60-linkedin": "remotion render src/index.ts AntiSlop60LinkedIn out/antislop60-linkedin.mp4",
    "render:antislop60-landscape": "remotion render src/index.ts AntiSlop60Landscape out/antislop60-landscape.mp4",
    "render:antislop60-all": "npm run render:antislop60-tiktok && npm run render:antislop60-linkedin && npm run render:antislop60-landscape",
    "render:roi": "remotion render src/index.ts RoiComparison out/roi-comparison.mp4",
    "render:roi:linkedin": "remotion render src/index.ts RoiComparisonLinkedIn out/roi-comparison-linkedin.mp4",
    "render:banner-nio": "remotion still src/index.ts NioBanner --image-format=png out/banner-nio.png",
    "render:banner-recon": "remotion still src/index.ts ReconBanner --image-format=png out/banner-recon.png",
    "render:banner-rem": "remotion still src/index.ts RemBanner --image-format=png out/banner-rem.png",
    "render:banner-unified": "remotion still src/index.ts UnifiedBanner --image-format=png out/banner-unified.png",
    "render:banners": "npm run render:banner-nio && npm run render:banner-recon && npm run render:banner-rem && npm run render:banner-unified",
    "render:claude-connect-still": "remotion still src/index.ts ClaudeConnectTeaserStill --image-format=png out/claude-connect-teaser.png",
    "render:claude-connect-gif": "remotion render src/index.ts ClaudeConnectTeaserAnimated out/claude-connect-teaser.gif --codec=gif",
    "render:claude-connect-mp4": "remotion render src/index.ts ClaudeConnectTeaserAnimated out/claude-connect-teaser.mp4",
    "render:claude-connect-all": "npm run render:claude-connect-still && npm run render:claude-connect-gif",
    "build": "echo 'Video app — use render scripts instead'"
  },
  "dependencies": {
    "@json-render/remotion": "^0.9.1",
    "@remotion/animation-utils": "^4.0.427",
    "@remotion/cli": "^4.0.0",
    "@remotion/gif": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "@remotion/motion-blur": "^4.0.427",
    "@remotion/noise": "^4.0.427",
    "@remotion/paths": "^4.0.427",
    "@remotion/player": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@remotion/transitions": "^4.0.427",
    "@shawnos/shared": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
